# Shopify App credentials — from Partner Dashboard
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SCOPES=read_products,write_products,read_themes,write_themes,read_orders,write_orders,read_customers,read_analytics,read_content,write_content,read_price_rules,write_price_rules,read_script_tags,write_script_tags,read_metafields,write_metafields

# App URL (ngrok / cloudflare tunnel / fly.io URL)
SHOPIFY_APP_URL=https://your-tunnel-url.ngrok-free.app

# PostgreSQL — local: postgresql://postgres:postgres@localhost:5432/split_test
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/split_test

# Redis — Upstash or local
REDIS_URL=redis://localhost:6379
# For Upstash: rediss://:<password>@<host>.upstash.io:6379

# Anthropic (Lift Assist — Phase 5)
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare (URL-redirect Worker — Phase 4)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Cookie signing secret — generate with: openssl rand -hex 32
COOKIE_SECRET=replace_with_random_hex_string

# Optional: override shop domain for testing
# SHOP_CUSTOM_DOMAIN=my-store.com
