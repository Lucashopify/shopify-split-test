{% comment %}
  Variant Content block — place this in the Theme Editor wherever you want
  test content to appear. Set the Experiment ID in block settings.
  In production the block is invisible until Split Test injects the
  correct variant's HTML (before the page is revealed).
{% endcomment %}

{% if request.design_mode %}
  <div style="padding:1rem 1.25rem;background:#f4f4f4;border:1px dashed #bbb;font-size:12px;color:#555;text-align:center;border-radius:4px">
    <strong>Split Test — Variant Content</strong><br>
    {% if block.settings.experiment_id != blank %}
      Experiment ID: {{ block.settings.experiment_id }}
    {% else %}
      ⚠ Set the Experiment ID in block settings
    {% endif %}
  </div>
{% else %}
  <div
    data-spt-section="{{ block.settings.experiment_id }}"
    style="visibility:hidden"
  ></div>
{% endif %}

{% schema %}
{
  "name": "Variant Content",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "experiment_id",
      "label": "Experiment ID",
      "info": "Copy the experiment ID from your Split Tester dashboard (Overview tab)."
    }
  ]
}
{% endschema %}
