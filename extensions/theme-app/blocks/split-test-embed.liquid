{% comment %}
  Split Test App — storefront embed block
  Enable via Theme Editor → App embeds → Split Test Embed
{% endcomment %}

<style>html.spt-loading{opacity:0!important;pointer-events:none}</style>
<script>
  window.__SPT_SHOP__ = {{ shop.permanent_domain | json }};
  {%- assign spt_raw = shop.metafields.split_test_app.config.value -%}
  {%- if spt_raw != blank -%}
  window.__SPT_CFG_INLINE__ = {{ spt_raw | json }};
  {%- endif -%}
</script>

<script src="{{ 'split-test-init.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Split Test Embed",
  "target": "head"
}
{% endschema %}
