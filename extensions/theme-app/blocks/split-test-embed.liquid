{% comment %}
  Split Test App — storefront embed block
  Enable via Theme Editor → App embeds → Split Test Embed
{% endcomment %}

<script>
  window.__SPT_SHOP__ = {{ shop.myshopify_domain | json }};
  {%- assign spt_raw = shop.metafields.split_test_app.config.value -%}
  {%- if spt_raw != blank -%}
  window.__SPT_CFG_INLINE__ = {{ spt_raw }};
  {%- endif -%}
</script>

{{ 'split-test-init.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Split Test Embed",
  "target": "head"
}
{% endschema %}
